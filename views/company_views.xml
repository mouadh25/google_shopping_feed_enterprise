<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_form_google_feed_enterprise" model="ir.ui.view">
        <field name="name">res.company.form.google.feed.enterprise</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='company_info']" position="after">
                <group string="Google Shopping Feed Enterprise" name="google_feed_enterprise">
                    <field name="google_feed_enterprise"/>
                    <field name="google_feed_enterprise_license"/>
                    <field name="google_feed_enterprise_status" readonly="1"/>
                    <button name="action_validate_google_feed_enterprise"
                            type="object"
                            string="Validate Enterprise License"
                            class="oe_highlight"/>
                    <button name="action_clear_google_feed_enterprise"
                            type="object"
                            string="Clear Enterprise License"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
